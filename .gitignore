# ─── Large Datasets — Keep folder structure only ─────────────────────────────
*.csv
*.zip
*.rar
*.gz
*.tar
*.tar.gz
data/raw/creditcard.csv
data/raw/creditcardfraud.zip
data/processed/*.csv

# ─── Preserve empty folder placeholders ─────────────────────────────────────
!data/
!data/processed/
!data/raw/

# ─── Logs ───────────────────────────────────────────────────────────────────
logs/*
!logs/.gitkeep
*.log

# ─── Model Binaries (large, tracked via MLflow/DVC instead) ─────────────────
models/*.pkl
models/*.bin
models/*.txt
models/*.json
!models/.gitkeep

